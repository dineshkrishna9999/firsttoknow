# ──────────────────────────────────────────────
# FirstToKnow — LLM Configuration
# Copy this to .env and fill in your values
# Any LiteLLM-supported model works!
# ──────────────────────────────────────────────

# ── Pick ONE provider, uncomment and add your key ──

# OpenAI (ChatGPT)
# OPENAI_API_KEY=sk-your_key
# FIRSTTOKNOW_MODEL=gpt-4o

# Azure OpenAI
# AZURE_API_KEY=your_key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-10-01-preview
# FIRSTTOKNOW_MODEL=azure/gpt-4.1

# Google Gemini
# GEMINI_API_KEY=your_key
# FIRSTTOKNOW_MODEL=gemini/gemini-2.0-flash

# Anthropic Claude
# ANTHROPIC_API_KEY=your_key
# FIRSTTOKNOW_MODEL=anthropic/claude-sonnet-4-20250514

# Groq (fast & cheap)
# GROQ_API_KEY=your_key
# FIRSTTOKNOW_MODEL=groq/llama-3.3-70b-versatile

# DeepSeek
# DEEPSEEK_API_KEY=your_key
# FIRSTTOKNOW_MODEL=deepseek/deepseek-chat

# Ollama (free, local — no key needed!)
# FIRSTTOKNOW_MODEL=ollama/llama3

# ──────────────────────────────────────────────
# Optional: GitHub token for higher API rate limits
# ──────────────────────────────────────────────
# GITHUB_TOKEN=ghp_your_token_here
